{
  "name": "earthengine",
  "displayName": "Earth Engine",
  "description": "Google Earth Engine Code Editor functionalities brought to VS Code",
  "version": "0.2.1",
  "publisher": "12rambau",
  "repository": {
    "type": "git",
    "url": "https://github.com/12rambau/earthengine-extension"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "earthengine-icon": {
        "description": "Earth Engine Icon",
        "default": {
          "fontPath": "resources/fonts/earthengine-icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "earthengine",
          "title": "Earth Engine",
          "icon": "resources/earthengine.svg"
        }
      ]
    },
    "views": {
      "earthengine": [
        {
          "id": "earthengine.profiles",
          "name": "Profiles"
        },
        {
          "id": "earthengine.assets",
          "name": "Assets"
        },
        {
          "id": "earthengine.docs",
          "name": "Docs"
        },
        {
          "id": "earthengine.tasks.export",
          "name": "Export Tasks"
        },
        {
          "id": "earthengine.tasks.import",
          "name": "Import Tasks"
        },
        {
          "id": "earthengine.dataset",
          "name": "Dataset"
        }
      ]
    },
    "commands": [
      {
        "command": "earthengine.showAuthStatus",
        "title": "Earth Engine: Show Authentication Status"
      },
      {
        "command": "earthengine.signIn",
        "title": "Add Profile",
        "icon": "$(person-add)"
      },
      {
        "command": "earthengine.addServiceAccount",
        "title": "Add Service Account",
        "icon": "$(file-add)"
      },
      {
        "command": "earthengine.signOut",
        "title": "Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "earthengine.activateProfile",
        "title": "Earth Engine: Activate Profile"
      },
      {
        "command": "earthengine.removeProfile",
        "title": "Remove Profile",
        "icon": "$(trash)"
      },
      {
        "command": "earthengine.refreshDocs",
        "title": "Earth Engine: Refresh API Docs",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.searchDocs",
        "title": "Earth Engine: Search API Docs",
        "icon": "$(search)"
      },
      {
        "command": "earthengine.refreshAssets",
        "title": "Refresh Assets",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.searchAssets",
        "title": "Earth Engine: Search Assets",
        "icon": "$(search)"
      },
      {
        "command": "earthengine.openAssetsPanel",
        "title": "Open Asset Manager",
        "icon": "$(open-preview)"
      },
      {
        "command": "earthengine.createFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "earthengine.refreshAssetFolder",
        "title": "Refresh Folder",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.openAssetPreview",
        "title": "Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "earthengine.copyAssetId",
        "title": "Copy Asset ID",
        "icon": "$(copy)"
      },
      {
        "command": "earthengine.deleteAsset",
        "title": "Earth Engine: Delete Asset",
        "icon": "$(trash)"
      },
      {
        "command": "earthengine.moveAsset",
        "title": "Earth Engine: Move Asset",
        "icon": "$(move)"
      },
      {
        "command": "earthengine.copyAsset",
        "title": "Earth Engine: Copy Asset",
        "icon": "$(files)"
      },
      {
        "command": "earthengine.refreshTasks",
        "title": "Earth Engine: Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.searchTasks",
        "title": "Earth Engine: Search Tasks",
        "icon": "$(search)"
      },
      {
        "command": "earthengine.cancelTask",
        "title": "Cancel Task",
        "icon": "$(close)"
      },
      {
        "command": "earthengine.newScript",
        "title": "New Python Script",
        "icon": "$(file-code)"
      },
      {
        "command": "earthengine.openMap",
        "title": "Open Map View",
        "icon": "$(map)"
      },
      {
        "command": "earthengine.openExportTasksPanel",
        "title": "Earth Engine: Open Export Tasks",
        "icon": "$(open-preview)"
      },
      {
        "command": "earthengine.openImportTasksPanel",
        "title": "Earth Engine: Open Import Tasks",
        "icon": "$(open-preview)"
      },
      {
        "command": "earthengine.refreshDatasets",
        "title": "Earth Engine: Refresh Datasets",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.searchDatasets",
        "title": "Earth Engine: Search Datasets",
        "icon": "$(search)"
      },
      {
        "command": "earthengine.openDatasetInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "earthengine.copyDatasetId",
        "title": "Copy Dataset ID",
        "icon": "$(copy)"
      },
      {
        "command": "earthengine.openDatasetPanel",
        "title": "Open Details",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "earthengine.signIn",
          "when": "view == earthengine.profiles",
          "group": "navigation"
        },
        {
          "command": "earthengine.addServiceAccount",
          "when": "view == earthengine.profiles",
          "group": "navigation"
        },
        {
          "command": "earthengine.openMap",
          "when": "view == earthengine.profiles",
          "group": "navigation"
        },
        {
          "command": "earthengine.searchAssets",
          "when": "view == earthengine.assets",
          "group": "navigation"
        },
        {
          "command": "earthengine.refreshAssets",
          "when": "view == earthengine.assets",
          "group": "navigation"
        },
        {
          "command": "earthengine.openAssetsPanel",
          "when": "view == earthengine.assets",
          "group": "navigation"
        },
        {
          "command": "earthengine.createFolder",
          "when": "view == earthengine.assets",
          "group": "navigation"
        },
        {
          "command": "earthengine.searchDocs",
          "when": "view == earthengine.docs",
          "group": "navigation"
        },
        {
          "command": "earthengine.refreshDocs",
          "when": "view == earthengine.docs",
          "group": "navigation"
        },
        {
          "command": "earthengine.searchTasks",
          "when": "view == earthengine.tasks.export || view == earthengine.tasks.import",
          "group": "navigation"
        },
        {
          "command": "earthengine.refreshTasks",
          "when": "view == earthengine.tasks.export || view == earthengine.tasks.import",
          "group": "navigation"
        },
        {
          "command": "earthengine.openExportTasksPanel",
          "when": "view == earthengine.tasks.export",
          "group": "navigation"
        },
        {
          "command": "earthengine.openImportTasksPanel",
          "when": "view == earthengine.tasks.import",
          "group": "navigation"
        },
        {
          "command": "earthengine.searchDatasets",
          "when": "view == earthengine.dataset",
          "group": "navigation"
        },
        {
          "command": "earthengine.refreshDatasets",
          "when": "view == earthengine.dataset",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "earthengine.removeProfile",
          "when": "viewItem == profile-active || viewItem == profile-inactive",
          "group": "inline"
        },
        {
          "command": "earthengine.newScript",
          "when": "viewItem == profile-active || viewItem == profile-inactive",
          "group": "inline"
        },
        {
          "command": "earthengine.refreshAssetFolder",
          "when": "viewItem =~ /^asset-container-/",
          "group": "inline"
        },
        {
          "command": "earthengine.createFolder",
          "when": "viewItem == asset-container-folder",
          "group": "inline"
        },
        {
          "command": "earthengine.openAssetPreview",
          "when": "viewItem =~ /^asset-(leaf|container)-(image|image_collection|table)$/",
          "group": "inline"
        },
        {
          "command": "earthengine.copyAssetId",
          "when": "viewItem =~ /^asset-/",
          "group": "inline"
        },
        {
          "command": "earthengine.copyAsset",
          "when": "viewItem =~ /^asset-/",
          "group": "1_modification@1"
        },
        {
          "command": "earthengine.moveAsset",
          "when": "viewItem =~ /^asset-/",
          "group": "1_modification@2"
        },
        {
          "command": "earthengine.deleteAsset",
          "when": "viewItem =~ /^asset-/",
          "group": "1_modification@3"
        },
        {
          "command": "earthengine.cancelTask",
          "when": "viewItem == task-running",
          "group": "inline"
        },
        {
          "command": "earthengine.openDatasetPanel",
          "when": "viewItem == dataset-item",
          "group": "inline"
        },
        {
          "command": "earthengine.openDatasetInBrowser",
          "when": "viewItem == dataset-item",
          "group": "inline"
        },
        {
          "command": "earthengine.copyDatasetId",
          "when": "viewItem == dataset-item",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/marked": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.6",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "marked": "^4.3.0"
  }
}
