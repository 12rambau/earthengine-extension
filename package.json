{
  "name": "earthengine",
  "displayName": "earthengine",
  "description": "earthengine code editor functionalities brought to VScode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "earthengine-icon": {
        "description": "Earth Engine Icon",
        "default": {
          "fontPath": "resources/fonts/earthengine-icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "earthengine",
          "title": "Earth Engine",
          "icon": "resources/earthengine.svg"
        }
      ]
    },
    "views": {
      "earthengine": [
        {
          "id": "earthengine.profiles",
          "name": "Profiles"
        },
        {
          "id": "earthengine.assets",
          "name": "Assets"
        },
        {
          "id": "earthengine.docs",
          "name": "Docs"
        },
        {
          "id": "earthengine.tasks",
          "name": "Tasks"
        },
        {
          "id": "earthengine.dataset",
          "name": "Dataset"
        }
      ]
    },
    "commands": [
      {
        "command": "earthengine.showAuthStatus",
        "title": "Earth Engine: Show Authentication Status"
      },
      {
        "command": "earthengine.signIn",
        "title": "Earth Engine: Sign In",
        "icon": "$(sign-in)"
      },
      {
        "command": "earthengine.signOut",
        "title": "Earth Engine: Sign Out"
      },
      {
        "command": "earthengine.activateProfile",
        "title": "Earth Engine: Activate Profile"
      },
      {
        "command": "earthengine.removeProfile",
        "title": "Remove Profile",
        "icon": "$(trash)"
      },
      {
        "command": "earthengine.refreshDocs",
        "title": "Earth Engine: Refresh API Docs",
        "icon": "$(refresh)"
      },
      {
        "command": "earthengine.searchDocs",
        "title": "Earth Engine: Search API Docs",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "earthengine.signIn",
          "when": "view == earthengine.profiles",
          "group": "navigation"
        },
        {
          "command": "earthengine.searchDocs",
          "when": "view == earthengine.docs",
          "group": "navigation"
        },
        {
          "command": "earthengine.refreshDocs",
          "when": "view == earthengine.docs",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "earthengine.removeProfile",
          "when": "viewItem == profile-inactive",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
